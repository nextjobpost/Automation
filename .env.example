# ── Telegram API (get from https://my.telegram.org) ────────
API_ID=your_telegram_api_id
API_HASH=your_telegram_api_hash

# ── Job Portal JWT Token ────────────────────────────────────
API_TOKEN=your_jwt_token_here

# ── Google Gemini AI Key (for job parsing) ──────────────────
API_KEY=your_gemini_api_key

# ── LinkedIn OAuth (run get_linkedin_token.py to generate) ──
# Token expires every ~60 days — re-run script to refresh
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_PERSON_URN=urn:li:person:your_person_id

# ── Adzuna Job API (for private jobs) ───────────────────────
# Get free keys at https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# ── Testing ─────────────────────────────────────────────────
# Set to True to mock API calls and generate outputs locally in /test_output
TEST_MODE=True
